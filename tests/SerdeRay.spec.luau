local frktest = require("@packages/frktest")
local test = frktest.test
local check = frktest.assert.check

local roblox = require("@lune/roblox")

local Writer = require("@src/buffer/Writer")
local Reader = require("@src/buffer/Reader")
local ray = require("@src/serde/ray")

return function()
	test.suite("serde.ray", function()
		test.case("round trip with a non-trivial ray", function()
			local value = roblox.Ray.new(roblox.Vector3.new(1, 2, 3), roblox.Vector3.new(4, 5, 6))
			local w = Writer.new()
			ray.write(w, value)
			local r = Reader.new(w:toBuffer())
			local result = ray.read(r)
			check.equal(result.Origin.X, value.Origin.X)
			check.equal(result.Origin.Y, value.Origin.Y)
			check.equal(result.Origin.Z, value.Origin.Z)
			check.equal(result.Direction.X, value.Direction.X)
			check.equal(result.Direction.Y, value.Direction.Y)
			check.equal(result.Direction.Z, value.Direction.Z)
		end)

		test.case("round trip with zero vectors", function()
			local value = roblox.Ray.new(roblox.Vector3.new(0, 0, 0), roblox.Vector3.new(0, 0, 0))
			local w = Writer.new()
			ray.write(w, value)
			local r = Reader.new(w:toBuffer())
			local result = ray.read(r)
			check.equal(result.Origin.X, value.Origin.X)
			check.equal(result.Origin.Y, value.Origin.Y)
			check.equal(result.Origin.Z, value.Origin.Z)
			check.equal(result.Direction.X, value.Direction.X)
			check.equal(result.Direction.Y, value.Direction.Y)
			check.equal(result.Direction.Z, value.Direction.Z)
		end)

		test.case("round trip with negative components", function()
			local value = roblox.Ray.new(roblox.Vector3.new(-1, -2, -3), roblox.Vector3.new(-4, -5, -6))
			local w = Writer.new()
			ray.write(w, value)
			local r = Reader.new(w:toBuffer())
			local result = ray.read(r)
			check.equal(result.Origin.X, value.Origin.X)
			check.equal(result.Origin.Y, value.Origin.Y)
			check.equal(result.Origin.Z, value.Origin.Z)
			check.equal(result.Direction.X, value.Direction.X)
			check.equal(result.Direction.Y, value.Direction.Y)
			check.equal(result.Direction.Z, value.Direction.Z)
		end)
	end)
end
